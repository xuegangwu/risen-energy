{
  "appId": "com.energystorage.groupbuy",
  "appName": "risen",
  "webDir": "dist",
  "server": {
    "url": "https://xuegangwu.github.io/risen-energy",
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "backgroundColor": "#0891b2",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_CROP"
    }
  },
  "ios": {
    "cordovaSwiftVersion": "5.0",
    "minVersion": "12.0"
  },
  "android": {
    "minSdkVersion": 22,
    "targetSdkVersion": 33
  }
}
